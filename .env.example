# =========================
# Server Config
# =========================
PORT=5002

# =========================
# Database (MongoDB)
# =========================
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=sk-...

# =========================
# Pinecone
# =========================
PINECONE_API_KEY=pcsk-...
PINECONE_ENV=us-east-1
PINECONE_HOST=https://<your-project>.svc.<region>.pinecone.io

# Indexes
PINECONE_INDEX=kurtis-agent
PINECONE_INDEX_THREADS=threads
PINECONE_INDEX_AGENTS=agents
PINECONE_INDEX_USERS=users
PINECONE_INDEX_PERSONAS=personas
PINECONE_INDEX_FEED=feed-events

# =========================
# Neo4j
# =========================
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-password>

# =========================
# News API
# =========================
NEWS_API_KEY=<your-news-api-key>

# =========================
# Twitter (OAuth2 / PKCE)
# =========================
TWITTER_CLIENT_ID=<your-client-id>
TWITTER_CLIENT_SECRET=<your-client-secret>
TWITTER_REDIRECT_URI=http://localhost:3000/api/twitter/callback

# =========================
# OSINT / LLM Config
# =========================
OSINT_MAX_SIGNALS_PER_RUN=50
OSINT_MAX_LLM_CALLS_PER_RUN=50
OSINT_LLM_MODEL=gpt-4o-mini
